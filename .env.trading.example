# Copy to .env.trading (gitignored) and fill in. Used by start-stockboard.sh
# to protect the publicly-funneled site with HTTP Basic Auth.
BASIC_AUTH_USER=icjj
BASIC_AUTH_PASSWORD=change-me

# Quiz / account-login (funnel only)
QUIZ_ENABLED=1
SESSION_SECRET=run: openssl rand -hex 32
COOKIE_SECURE=1   # 1 for HTTPS funnel; set 0 only for plain-http localhost testing
